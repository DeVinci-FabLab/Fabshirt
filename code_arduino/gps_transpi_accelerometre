#include <Arduino.h>
#include <Wire.h>
#include <SparkFun_u-blox_GNSS_Arduino_Library.h>
#include "SparkFun_BMA400_Arduino_Library.h"

// --- GPS Setup ---
SFE_UBLOX_GNSS gps;

// --- BMA400 Setup ---
BMA400 accelerometer;
uint8_t i2cAddress = BMA400_I2C_ADDRESS_DEFAULT; // 0x14

// --- Analog Sensor Setup ---
const int analogPin = A0;
const float VCC = 3.3;
const float R1 = 100000.0;

void setup() {
  // Start serial
  Serial.begin(115200);
  delay(2000);

  Serial.println("Initialisation GPS et BMA400 + capteur analogique");

  // Initialize I2C
  Wire.begin();
  delay(100);

  // Initialize GPS
  if (!gps.begin()) {
    Serial.println("GPS non detecte !");
    while (1);
  }
  Serial.println("GPS detecte");

  // Initialize BMA400
  while (accelerometer.beginI2C(i2cAddress) != BMA400_OK) {
    Serial.println("Error: BMA400 not connected, check wiring!");
    delay(1000);
  }
  Serial.println("BMA400 connected!");
}

void loop() {
  // --- GPS ---
  gps.checkUblox();

  int fixType = gps.getFixType();
  int satellitesVisible = gps.getSIV();

  Serial.println("GPS DEBUG");
  Serial.print("Fix Type: ");
  Serial.println(fixType); // 0 = aucun fix, 2 = 2D, 3 = 3D
  Serial.print("Satellites visibles: ");
  Serial.println(satellitesVisible);

  if (fixType > 0) {
    Serial.print("Latitude : ");
    Serial.println(gps.getLatitude() / 10000000.0, 7);

    Serial.print("Longitude: ");
    Serial.println(gps.getLongitude() / 10000000.0, 7);

    Serial.print("Altitude : ");
    Serial.println(gps.getAltitude() / 1000.0);
  } else {
    Serial.println("Recherche satellites...");
  }

  // --- BMA400 ---
  accelerometer.getSensorData();
  Serial.print("Accel (g) -> X: ");
  Serial.print(accelerometer.data.accelX, 3);
  Serial.print("\tY: ");
  Serial.print(accelerometer.data.accelY, 3);
  Serial.print("\tZ: ");
  Serial.println(accelerometer.data.accelZ, 3);

  // --- Analog Sensor ---
  int adcValue = analogRead(analogPin);
  float Vout = adcValue * (VCC / 1023.0);
  float R2 = R1 * Vout / (VCC - Vout);

  Serial.print("ADC Value: ");
  Serial.print(adcValue);
  Serial.print(" | Vout: ");
  Serial.print(Vout, 3);
  Serial.print(" V | R2: ");
  Serial.print(R2 / 1000.0, 2);
  Serial.println(" kΩ");

  Serial.println("---------------------------");
  delay(1000); // 1 lecture par seconde
}
