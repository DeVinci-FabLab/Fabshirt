#include <Arduino.h>

const int ecgPin = A0;   // Pin analogique où est branché le capteur ECG

void setup() 
{
  Serial.begin(115200);
  Serial.println("Lecture du capteur ECG");
}

void loop() 
{
  int ecgValue = analogRead(ecgPin);  // lecture du signal ECG

  Serial.print("ECG: ");
  Serial.println(ecgValue);           // envoie la valeur vers le moniteur série

  delay(5); // petite pause pour stabiliser la lecture
}

//OU 
//capteur ECG
const int analogPin = A0;
const float VCC = 3.3;       
const float R1 = 100000.0; 

void setup() 
{
  Serial.begin(115200);
}

void loop() 
{
  int adcValue = analogRead(analogPin);
  float Vout = adcValue * (VCC / 1023.0);
  float R2 = R1 * Vout / (VCC - Vout);
  
  Serial.print("ADC Value: ");
  Serial.print(adcValue);
  Serial.print(" | Vout: ");
  Serial.print(Vout, 3);
  Serial.print(" V | R2 necessaire: ");
  Serial.print(R2 / 1000.0, 2);  
  Serial.println(" kΩ");

  delay(1000);
}